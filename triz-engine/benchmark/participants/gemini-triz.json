{
  "name": "gemini-triz",
  "version": "1.0.0",
  "description": "Gemini 2.5 Pro with identical TRIZ system prompt (external competitor, requires GOOGLE_API_KEY)",
  "type": "external",
  "invocation": {
    "command": "python3",
    "args": ["benchmark/runners/gemini_runner.py", "--model", "gemini-2.5-pro", "--system-prompt-file", "commands/analyze.md", "--problem-file", "{problem_file}"],
    "timeout_seconds": 180,
    "requires_env": ["GOOGLE_API_KEY"]
  },
  "features": ["system_prompt", "external_model"]
}
